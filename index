<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LPS Talent Quest — Integrated Talent Management</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap');

:root{
  --orange:#F58220;
  --gold:#E8941A;
  --deep:#C75A0E;
  --ember:#FF6B2C;
  /* beige palette */
  --bg0:#F4EBDD;
  --bg1:#EFE3D0;
  --paper:#FFFDF8;
  --paper2:#FBF4E8;
  --stroke:rgba(199,90,14,.16);
  --stroke2:rgba(199,90,14,.32);
  --ink:#3A2A1B;
  --ink-dim:#7A6450;
  --ink-faint:#A8957F;
  --good:#3FA86B;
  --shadow:0 6px 22px rgba(120,72,20,.10);
  --shadow-sm:0 3px 12px rgba(120,72,20,.08);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'Inter',sans-serif;
  background:
    radial-gradient(1100px 520px at 85% -8%, rgba(245,130,32,.16), transparent 60%),
    radial-gradient(800px 460px at -5% 105%, rgba(232,148,26,.12), transparent 55%),
    var(--bg0);
  color:var(--ink);
  min-height:100vh;overflow-x:hidden;
}
.wrap{max-width:1180px;margin:0 auto;padding:0 22px}

/* top bar */
.topbar{position:sticky;top:0;z-index:50;backdrop-filter:blur(12px);
  background:linear-gradient(180deg,rgba(244,235,221,.94),rgba(244,235,221,.66));
  border-bottom:1px solid var(--stroke)}
.topbar .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}
.logo{display:flex;align-items:center;gap:12px}
.logo .hex{filter:drop-shadow(0 4px 10px rgba(245,130,32,.35))}
.logo .name .b{font-family:'Sora';font-weight:800;font-size:18px;letter-spacing:.4px;color:var(--ink)}
.logo .name .b span{color:var(--deep)}
.logo .name .s{font-size:9.5px;color:var(--ink-faint);font-weight:600;letter-spacing:.6px}
.nav{display:flex;gap:5px;flex-wrap:wrap}
.nav button{font-family:'Inter';font-size:12.5px;font-weight:600;color:var(--ink-dim);
  background:transparent;border:1px solid transparent;border-radius:10px;padding:8px 13px;cursor:pointer;transition:.18s}
.nav button:hover{color:var(--ink);background:rgba(245,130,32,.1)}
.nav button.active{color:#fff;background:linear-gradient(135deg,var(--gold),var(--orange));
  box-shadow:0 4px 14px rgba(245,130,32,.34)}

/* hero */
.hero{padding:28px 0 14px}
.hero-card{position:relative;background:linear-gradient(135deg,rgba(245,130,32,.10),rgba(255,253,248,.6)),var(--paper);
  border:1px solid var(--stroke2);border-radius:22px;padding:24px 28px;box-shadow:var(--shadow);
  display:grid;grid-template-columns:auto 1fr auto;gap:26px;align-items:center;overflow:hidden}
.hero-card::after{content:"";position:absolute;right:-90px;top:-90px;width:320px;height:320px;
  background:radial-gradient(circle,rgba(245,130,32,.16),transparent 70%);pointer-events:none}
.av-ring{position:relative;width:140px;height:140px;flex-shrink:0}
.av-ring svg.ring{position:absolute;inset:0;transform:rotate(-90deg)}
.av-frame{position:absolute;inset:9px;border-radius:50%;overflow:hidden;border:2px solid rgba(245,130,32,.55);
  background:linear-gradient(180deg,#dfe7f0,#c6d2e0);box-shadow:inset 0 0 24px rgba(120,72,20,.12)}
.av-frame svg{width:100%;height:100%;display:block}
.lvl-badge{position:absolute;bottom:2px;right:2px;z-index:3;width:42px;height:42px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--deep));border:3px solid var(--paper);
  display:flex;flex-direction:column;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(120,72,20,.4)}
.lvl-badge .lv{font-size:7px;font-weight:700;color:rgba(255,255,255,.85);line-height:1;margin-top:3px}
.lvl-badge .num{font-family:'Sora';font-size:17px;font-weight:800;color:#fff;line-height:1}

.hero-info .eyebrow{font-size:11px;font-weight:700;color:var(--deep);letter-spacing:2px;text-transform:uppercase}
.hero-info h1{font-family:'Sora';font-size:32px;font-weight:800;margin:4px 0 6px;letter-spacing:-.5px;color:var(--ink)}
.hero-info .titles{display:flex;align-items:center;gap:9px;flex-wrap:wrap;color:var(--ink-dim);font-size:13px;font-weight:500}
.hero-info .titles .dot{width:4px;height:4px;border-radius:50%;background:var(--ink-faint)}
.cls-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(245,130,32,.14);border:1px solid var(--stroke2);
  color:var(--deep);font-size:11.5px;font-weight:700;padding:4px 10px;border-radius:20px}
/* quick stats inline */
.qstats{display:flex;gap:18px;margin-top:14px;flex-wrap:wrap}
.qstat{display:flex;align-items:center;gap:8px}
.qstat .qi{width:30px;height:30px;border-radius:9px;background:rgba(245,130,32,.12);display:flex;align-items:center;justify-content:center;font-size:15px}
.qstat .qt .k{font-size:9px;color:var(--ink-faint);font-weight:700;letter-spacing:.5px;text-transform:uppercase}
.qstat .qt .v{font-size:13px;font-weight:700;color:var(--ink)}
.xp-wrap{margin-top:15px;max-width:440px}
.xp-top{display:flex;justify-content:space-between;font-size:11px;font-weight:600;margin-bottom:6px}
.xp-top .l{color:var(--ink-dim)}.xp-top .r{color:var(--deep)}
.xp-track{height:10px;background:rgba(199,90,14,.1);border-radius:20px;overflow:hidden;border:1px solid rgba(199,90,14,.12)}
.xp-fill{height:100%;width:0;border-radius:20px;background:linear-gradient(90deg,var(--deep),var(--gold));
  box-shadow:0 0 10px rgba(232,148,26,.5);transition:width 1.6s cubic-bezier(.2,.8,.2,1);position:relative}
.xp-fill::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.5),transparent);animation:shine 2.4s linear infinite}
@keyframes shine{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

.ready{text-align:center;flex-shrink:0;position:relative;z-index:2;background:var(--paper2);
  border:1px solid var(--stroke2);border-radius:18px;padding:16px 20px;min-width:132px;box-shadow:var(--shadow-sm)}
.ready .cap{font-size:9.5px;font-weight:700;color:var(--ink-faint);letter-spacing:1.5px;text-transform:uppercase}
.ready .big{font-family:'Sora';font-size:30px;font-weight:800;
  background:linear-gradient(135deg,var(--gold),var(--ember));-webkit-background-clip:text;background-clip:text;color:transparent;line-height:1.1;margin:4px 0 6px}
.ready .pips{display:flex;gap:5px;justify-content:center}
.ready .pip{width:22px;height:6px;border-radius:4px;background:rgba(199,90,14,.16)}
.ready .pip.on{background:linear-gradient(90deg,var(--gold),var(--orange));box-shadow:0 0 6px rgba(232,148,26,.4)}
.ready .sub{font-size:9.5px;color:var(--ink-faint);margin-top:8px}

/* tabs */
.tabwrap{padding:8px 0 50px}
.panel-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:18px;margin-top:6px}
.card{background:var(--paper);border:1px solid var(--stroke);border-radius:18px;padding:18px 20px;position:relative;box-shadow:var(--shadow-sm)}
.card h3{font-family:'Sora';font-size:13px;font-weight:700;letter-spacing:.4px;display:flex;align-items:center;gap:9px;margin-bottom:14px;text-transform:uppercase;color:var(--ink)}
.card h3 .ic{width:26px;height:26px;border-radius:8px;background:rgba(245,130,32,.13);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.card h3 .ic svg{width:15px;height:15px}
.card h3 .tag{margin-left:auto;font-size:9px;font-weight:700;color:var(--deep);background:rgba(245,130,32,.12);padding:3px 8px;border-radius:10px;letter-spacing:.5px}

.radar-card{display:flex;flex-direction:column;align-items:center}
#radar{width:100%;max-width:380px}
.radar-legend{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:6px}
.radar-legend span{font-size:10px;color:var(--ink-dim);display:flex;align-items:center;gap:5px}
.radar-legend i{width:8px;height:8px;border-radius:2px;background:var(--orange);display:inline-block}

.skill{margin-bottom:13px}.skill:last-child{margin-bottom:0}
.skill .top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.skill .nm{font-size:12.5px;font-weight:600;display:flex;align-items:center;gap:8px;color:var(--ink)}
.skill .nm .emoji{font-size:14px}
.skill .lv{font-family:'Sora';font-size:11px;font-weight:700}
.skill.locked .nm{color:var(--ink-faint)}.skill.locked .lv{color:var(--ink-faint)}
.skill .lv.active{color:var(--deep)}
.pips-row{display:flex;gap:4px}
.pips-row .p{height:8px;flex:1;border-radius:3px;background:rgba(199,90,14,.1);transition:.5s}
.pips-row .p.fill{background:linear-gradient(90deg,var(--orange),var(--gold));box-shadow:0 0 5px rgba(232,148,26,.35)}
.pips-row .p.maxed{background:linear-gradient(90deg,var(--gold),var(--ember))}

.quest{display:flex;gap:12px;padding:11px 0;border-bottom:1px dashed rgba(199,90,14,.14)}
.quest:last-child{border-bottom:none;padding-bottom:0}
.quest .q-ic{width:34px;height:34px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:rgba(245,130,32,.1);border:1px solid var(--stroke);font-size:16px}
.quest .q-body{flex:1}
.quest .q-title{font-size:12.5px;font-weight:600;color:var(--ink)}
.quest .q-meta{font-size:10.5px;color:var(--ink-faint);margin-top:2px}
.quest .q-xp{font-size:10px;font-weight:700;color:var(--good);background:rgba(63,168,107,.12);padding:3px 8px;border-radius:9px;height:fit-content;white-space:nowrap}

.badge-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.bdg{text-align:center;padding:12px 6px;border-radius:13px;border:1px solid var(--stroke);background:linear-gradient(180deg,rgba(245,130,32,.07),transparent)}
.bdg.lock{opacity:.45;filter:grayscale(.5)}
.bdg .em{font-size:24px}.bdg .bn{font-size:9.5px;font-weight:600;margin-top:5px;color:var(--ink-dim)}

.chips{display:flex;flex-wrap:wrap;gap:8px}
.chip{font-size:11.5px;font-weight:600;padding:7px 13px;border-radius:20px;background:rgba(245,130,32,.1);border:1px solid var(--stroke);color:var(--deep);transition:.2s;cursor:default}
.chip:hover{background:rgba(245,130,32,.18);transform:translateY(-1px)}

.irow{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(199,90,14,.08);font-size:12.5px}
.irow:last-child{border-bottom:none}
.irow .k{color:var(--ink-faint);font-weight:500}
.irow .v{font-weight:700;text-align:right;color:var(--ink)}
.irow .v small{color:var(--deep);font-weight:600}

/* attendance pie */
.att-card{display:flex;gap:22px;align-items:center;flex-wrap:wrap}
#attpie{width:200px;height:200px;flex-shrink:0}
.att-legend{flex:1;min-width:180px}
.att-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid rgba(199,90,14,.08)}
.att-row:last-child{border-bottom:none}
.att-row .sw{width:13px;height:13px;border-radius:4px;flex-shrink:0}
.att-row .al{flex:1;font-size:12px;font-weight:600;color:var(--ink)}
.att-row .ap{font-size:12px;font-weight:700;color:var(--ink)}
.att-row .ad{font-size:10.5px;color:var(--ink-faint);font-weight:500}

/* aspiration goal cards */
.goal{display:flex;gap:13px;padding:13px;border:1px solid var(--stroke);border-radius:14px;margin-bottom:11px;background:var(--paper2);transition:.2s}
.goal:last-child{margin-bottom:0}
.goal:hover{border-color:var(--stroke2);transform:translateX(3px)}
.goal .g-ic{width:42px;height:42px;border-radius:11px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:20px;background:linear-gradient(135deg,rgba(245,130,32,.18),rgba(232,148,26,.08));border:1px solid var(--stroke)}
.goal .g-body{flex:1}
.goal .g-title{font-size:13px;font-weight:700;color:var(--ink)}
.goal .g-meta{font-size:10.5px;color:var(--ink-faint);margin-top:2px}
.goal .g-prog{margin-top:7px;height:6px;background:rgba(199,90,14,.1);border-radius:10px;overflow:hidden}
.goal .g-prog i{display:block;height:100%;border-radius:10px;background:linear-gradient(90deg,var(--orange),var(--gold))}
.goal .g-right{display:flex;flex-direction:column;align-items:flex-end;justify-content:center;gap:6px}
.goal .g-xp{font-size:10px;font-weight:700;color:var(--good);background:rgba(63,168,107,.12);padding:3px 9px;border-radius:9px;white-space:nowrap}
.goal .g-pct{font-size:10px;font-weight:700;color:var(--deep)}

/* talent/interest tiles */
.talent-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:11px}
.talent{padding:14px;border-radius:14px;border:1px solid var(--stroke);background:var(--paper2);position:relative;overflow:hidden}
.talent .tem{font-size:22px}
.talent .tnm{font-size:12.5px;font-weight:700;color:var(--ink);margin-top:7px}
.talent .tlv{font-size:9.5px;font-weight:600;color:var(--deep);margin-top:3px;text-transform:uppercase;letter-spacing:.4px}
.talent .tbar{margin-top:8px;height:5px;background:rgba(199,90,14,.1);border-radius:8px;overflow:hidden}
.talent .tbar i{display:block;height:100%;border-radius:8px;background:linear-gradient(90deg,var(--orange),var(--gold))}

.foot{text-align:center;padding:18px 0 30px;color:var(--ink-faint);font-size:11px}
.foot b{color:var(--ink-dim)}

.tab-content{display:none;animation:fade .4s ease}
.tab-content.show{display:block}
@keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

@media(max-width:880px){
  .hero-card{grid-template-columns:1fr;text-align:center;justify-items:center}
  .qstats{justify-content:center}
  .panel-grid{grid-template-columns:1fr}
  .nav{display:none}
}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>

<div class="topbar">
  <div class="wrap">
    <div class="logo">
      <svg class="hex" width="34" height="38" viewBox="0 0 46 50">
        <defs><linearGradient id="hx" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#FBB040"/><stop offset="1" stop-color="#F58220"/></linearGradient></defs>
