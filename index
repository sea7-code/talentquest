            <div class="irow"><span class="k">Unit Kerja</span><span class="v">Grup Manajemen Risiko <small>· 3 thn</small></span></div>
            <div class="irow"><span class="k">Pendidikan Terkini</span><span class="v">S2 Magister Manajemen <small>· 2021</small></span></div>
            <div class="irow"><span class="k">Class / Archetype</span><span class="v">Risk Strategist</span></div>
          </div>
          <div class="card">
            <h3><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#C75A0E" stroke-width="2"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4L12 16.8 5.7 21.4 8 14 2 9.4h7.6z"/></svg></span>Achievement Badges</h3>
            <div class="badge-grid">
              <div class="bdg"><div class="em">🛡️</div><div class="bn">Risk Guardian</div></div>
              <div class="bdg"><div class="em">🎓</div><div class="bn">Magister</div></div>
              <div class="bdg"><div class="em">🏦</div><div class="bn">Banking Pro</div></div>
              <div class="bdg lock"><div class="em">⚖️</div><div class="bn">Legal Eagle</div></div>
            </div>
          </div>
