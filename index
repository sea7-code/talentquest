<script>
const btns=document.querySelectorAll('.nav button');
btns.forEach(b=>b.addEventListener('click',()=>{
  btns.forEach(x=>x.classList.remove('active'));b.classList.add('active');
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('show'));
  document.getElementById(b.dataset.tab).classList.add('show');
  if(b.dataset.tab==='skills')renderSkills();
  if(b.dataset.tab==='journey')buildPie();
}));

/* radar */
const axes=[
  {label:'Leadership',v:.78},{label:'Management',v:.72},{label:'Risk Mgmt',v:.88},
  {label:'Public Policy',v:.6},{label:'Digital Tech',v:.68},{label:'Special Skills',v:.82},
];
function buildRadar(){
  const svg=document.getElementById('radar');const cx=200,cy=160,R=108,N=axes.length;
  const pt=(i,r)=>{const a=-Math.PI/2+i*2*Math.PI/N;return[cx+r*Math.cos(a),cy+r*Math.sin(a)];};
  let h='';
  for(let k=4;k>=1;k--){const r=R*k/4;let p='';for(let i=0;i<N;i++){const[x,y]=pt(i,r);p+=`${x.toFixed(1)},${y.toFixed(1)} `;}
    h+=`<polygon points="${p}" fill="${k===4?'rgba(245,130,32,.04)':'none'}" stroke="rgba(199,90,14,.14)" stroke-width="1"/>`;}
  for(let i=0;i<N;i++){const[x,y]=pt(i,R);h+=`<line x1="${cx}" y1="${cy}" x2="${x}" y2="${y}" stroke="rgba(199,90,14,.14)" stroke-width="1"/>`;
    const[lx,ly]=pt(i,R+26);let a='middle';if(lx>cx+10)a='start';else if(lx<cx-10)a='end';
    h+=`<text x="${lx}" y="${ly}" text-anchor="${a}" font-family="Sora,Arial" font-size="10.5" font-weight="700" fill="#7A6450" dominant-baseline="middle">${axes[i].label.toUpperCase()}</text>`;}
  let pmax='';for(let i=0;i<N;i++){const[x,y]=pt(i,R);pmax+=`${x},${y} `;}
  h+=`<polygon points="${pmax}" fill="rgba(245,130,32,.05)" stroke="rgba(199,90,14,.28)" stroke-width="1" stroke-dasharray="3 3"/>`;
  let pdat='';const dots=[];for(let i=0;i<N;i++){const[x,y]=pt(i,R*axes[i].v);pdat+=`${x.toFixed(1)},${y.toFixed(1)} `;dots.push([x,y]);}
  h+=`<defs><radialGradient id="rg" cx="50%" cy="45%" r="60%"><stop offset="0%" stop-color="#FBB040" stop-opacity=".55"/><stop offset="100%" stop-color="#F58220" stop-opacity=".3"/></radialGradient></defs>`;
  h+=`<polygon id="datapoly" points="${pmax}" fill="url(#rg)" stroke="#F58220" stroke-width="2.2" style="transition:all 1.3s cubic-bezier(.2,.8,.2,1)"/>`;
  dots.forEach(([x,y])=>{h+=`<circle cx="${x}" cy="${y}" r="3.2" fill="#F58220" stroke="#FFFDF8" stroke-width="1.5"/>`;});
  svg.innerHTML=h;requestAnimationFrame(()=>{setTimeout(()=>{document.getElementById('datapoly').setAttribute('points',pdat);},250);});
}

/* skills */
const special=[
  {nm:'Banking',emoji:'🏦',lv:3,max:5,locked:false},
  {nm:'Finance',emoji:'💰',lv:2,max:5,locked:false},
  {nm:'Insurance',emoji:'🛡️',lv:0,max:5,locked:true},
  {nm:'Legal',emoji:'⚖️',lv:0,max:5,locked:true},
];
const core=[
  {nm:'Leadership',emoji:'⭐',lv:4,max:5,locked:false},
  {nm:'Management',emoji:'🗂️',lv:4,max:5,locked:false},
  {nm:'Risk Management',emoji:'📉',lv:4,max:5,locked:false},
  {nm:'Public Policy',emoji:'🏛️',lv:3,max:5,locked:false},
  {nm:'Digital Technology',emoji:'💻',lv:3,max:5,locked:false},
];
function skillHTML(s){let pips='';for(let i=0;i<s.max;i++){let c=i<s.lv?(s.lv===s.max?'p maxed':'p fill'):'p';pips+=`<span class="${c}" style="transition-delay:${i*90}ms"></span>`;}
  const t=s.locked?'LOCKED':`Lv. ${s.lv}`;
  return `<div class="skill ${s.locked?'locked':''}"><div class="top"><div class="nm"><span class="emoji">${s.emoji}</span>${s.nm}</div><div class="lv ${s.locked?'':'active'}">${t}</div></div><div class="pips-row">${pips}</div></div>`;}
let skillsRendered=false;
function renderSkills(){if(skillsRendered)return;skillsRendered=true;
  document.getElementById('specialSkills').innerHTML=special.map(skillHTML).join('');
  document.getElementById('coreSkills').innerHTML=core.map(skillHTML).join('');}

/* attendance pie */
const att=[
  {l:'Hadir',d:'214 hari',v:88,c:'#3FA86B'},
  {l:'Cuti',d:'12 hari',v:5,c:'#E8941A'},
  {l:'Dinas Luar / WFA',d:'10 hari',v:4,c:'#F58220'},
  {l:'Sakit / Izin',d:'7 hari',v:3,c:'#C75A0E'},
];
let pieBuilt=false;
function buildPie(){
  if(pieBuilt)return;pieBuilt=true;
  const svg=document.getElementById('attpie');const cx=100,cy=100,r=80,ir=46;
  let ang=-Math.PI/2;let h='';const total=att.reduce((s,a)=>s+a.v,0);
  att.forEach(a=>{
    const sweep=a.v/total*2*Math.PI;const a2=ang+sweep;
    const x1=cx+r*Math.cos(ang),y1=cy+r*Math.sin(ang);
    const x2=cx+r*Math.cos(a2),y2=cy+r*Math.sin(a2);
    const xi1=cx+ir*Math.cos(a2),yi1=cy+ir*Math.sin(a2);
    const xi2=cx+ir*Math.cos(ang),yi2=cy+ir*Math.sin(ang);
    const large=sweep>Math.PI?1:0;
    h+=`<path d="M${x1.toFixed(2)},${y1.toFixed(2)} A${r},${r} 0 ${large} 1 ${x2.toFixed(2)},${y2.toFixed(2)} L${xi1.toFixed(2)},${yi1.toFixed(2)} A${ir},${ir} 0 ${large} 0 ${xi2.toFixed(2)},${yi2.toFixed(2)} Z" fill="${a.c}" opacity="0" stroke="#FFFDF8" stroke-width="2"><animate attributeName="opacity" to="1" dur="0.5s" begin="${att.indexOf(a)*0.12}s" fill="freeze"/></path>`;
    ang=a2;
  });
  h+=`<text x="100" y="94" text-anchor="middle" font-family="Sora,Arial" font-size="26" font-weight="800" fill="#3A2A1B">88%</text>`;
  h+=`<text x="100" y="112" text-anchor="middle" font-family="Inter,Arial" font-size="10" font-weight="600" fill="#A8957F">KEHADIRAN</text>`;
  svg.innerHTML=h;
  document.getElementById('attLegend').innerHTML=att.map(a=>
    `<div class="att-row"><span class="sw" style="background:${a.c}"></span><span class="al">${a.l}</span><span class="ad">${a.d}</span>&nbsp;<span class="ap">${a.v}%</span></div>`).join('');
}

window.addEventListener('load',()=>{
  buildRadar();
  setTimeout(()=>{document.getElementById('xpfill').style.width='74%';
    document.getElementById('ringfill').style.transition='stroke-dashoffset 1.6s cubic-bezier(.2,.8,.2,1)';
    document.getElementById('ringfill').style.strokeDashoffset=402*(1-0.74);},300);
  let cur=0;const t=74;const tx=document.getElementById('xptxt');
  const iv=setInterval(()=>{cur+=2;if(cur>=t){cur=t;clearInterval(iv);}tx.textContent=cur+' / 100';},36);
});
</script>
