  </div>
</div>

<div class="tabwrap">
  <div class="wrap">

    <!-- TAB PROFILE -->
    <div class="tab-content show" id="profile">
      <div class="panel-grid">
        <div class="card radar-card">
          <h3 style="align-self:flex-start"><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#C75A0E" stroke-width="2"><polygon points="12 2 22 8.5 18 21 6 21 2 8.5"/></svg></span>Competency Radar <span class="tag">LIVE STATS</span></h3>
