</div>

<!-- HERO -->
<div class="hero">
  <div class="wrap">
    <div class="hero-card">
      <div class="av-ring">
        <svg class="ring" width="140" height="140" viewBox="0 0 140 140">
          <circle cx="70" cy="70" r="64" fill="none" stroke="rgba(199,90,14,.14)" stroke-width="6"/>
