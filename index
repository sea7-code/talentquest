        <div style="display:flex;flex-direction:column;gap:18px">
          <div class="card">
            <h3><span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="#C75A0E" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg></span>Profil Pegawai</h3>
